# ========================================================================
# 🛡️ NIS2 CYBERSHIELD SYSTEM ENVIRONMENTS TEMPLATE
# ========================================================================
# Copy this file to '.env' at the root of the workspace to override settings.
#

# 1. DATABASE CONFIGURATION
# SQLite (Local default zero-friction development)
DATABASE_URL=sqlite:///./nis2_compliance.db
# PostgreSQL (Production Docker Compose)
# DATABASE_URL=postgresql://nis2_admin:SecretPassword123@db:5432/nis2_compliance

# 2. TASK QUEUE & SCHEDULER (Redis broker)
REDIS_URL=redis://localhost:6379/0
# REDIS_URL=redis://redis:6379/0 (Docker network)

# 3. AI REASONING & OSINT KEYS (Required for full capabilities)
# Google Gemini API (Required for plain-language RAG remediation advice)
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere

# Shodan API Key (Required for scanning public ports footprint OSINT threat data)
SHODAN_API_KEY=YourShodanApiKeyHere

# 4. CHANNELS ALERTS & WEBHOOKS (Optional)
# Slack Incident Channel Webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/your-slack-webhook-here

# 5. CYBERSHIELD PERIMETER SCAN DEFAULTS
DEFAULT_SCAN_TARGET=192.168.1.0/24
DEFAULT_SCAN_FREQUENCY_MINS=60
